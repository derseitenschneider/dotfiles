{
  "_comment": "Merge these into your composer.json 'scripts' block. Replace {slug} with your plugin slug. Adjust --exclude to match your repo's non-source directories. Requires WP-CLI on PATH.",
  "scripts": {
    "i18n:pot":  "wp i18n make-pot . languages/{slug}.pot --domain={slug} --slug={slug} --exclude=node_modules,vendor,tests,build-output,dist",
    "i18n:po":   "wp i18n update-po languages/{slug}.pot languages/",
    "i18n:mo":   "wp i18n make-mo languages/",
    "i18n:json": "wp i18n make-json languages/ --no-purge",
    "i18n:all": [
      "@i18n:pot",
      "@i18n:po",
      "@i18n:mo",
      "@i18n:json"
    ]
  }
}
